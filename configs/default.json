    "max_epochs": 20,
    "no_improv": 3,
    "bucket_train_data": true,
    "decoder_max_iterations": 12,
    "sentence_train_batch_size": 16,
    "sentence_eval_batch_size": 16,
    "number_of_runs": 5,
    "logger_frequency": 20,
    "UNK": "$UNK$",
    "NUM": "$NUM$",
    "NONE": "O",
    "SOS": "$SOS$",
    "EOS": "$EOS$",
    "PAD": "$PAD$"
}
